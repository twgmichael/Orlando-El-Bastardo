# Studio Harness — application environment
# Managed by Ansible. Do not edit manually.

DATABASE_URL=postgresql+asyncpg://harness:{{ oeb_studio_harness_db_password }}@postgres:5432/harness
OEB_ENVIRONMENT={{ oeb_environment }}
API_ADMIN_TOKEN={{ oeb_studio_harness_admin_token }}
WORKER_ENROLLMENT_TOKEN={{ oeb_studio_harness_worker_enrollment_token }}
APP_SIGNING_SECRET={{ oeb_studio_harness_signing_secret }}

WORKER_HEARTBEAT_SECONDS={{ oeb_studio_harness_worker_heartbeat_seconds }}
WORKER_TIMEOUT_SECONDS={{ oeb_studio_harness_worker_timeout_seconds }}
JOB_LEASE_SECONDS={{ oeb_studio_harness_job_lease_seconds }}

ARTIFACTS_ROOT=/srv/oeb-studio-harness/artifacts
ARTIFACT_PUBLIC_BASE_URL={{ oeb_studio_harness_artifact_public_base_url }}
ARTIFACT_WORKER_PATH_PREFIX={{ oeb_studio_harness_artifact_worker_path_prefix }}
ARTIFACT_SERVER_PATH_PREFIX={{ oeb_studio_harness_artifact_server_path_prefix }}
TIMEZONE={{ oeb_studio_harness_timezone }}
OEB_STUDIO_CHAT_OLLAMA_URL={{ oeb_studio_chat_ollama_url }}
OEB_STUDIO_CHAT_MODEL={{ oeb_studio_chat_model }}
OEB_STUDIO_CHAT_HARNESS_URL={{ oeb_studio_chat_harness_url }}
OEB_STUDIO_CHAT_ADMIN_TOKEN={{ oeb_studio_chat_admin_token }}
