{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "oeb:camera-grammar:1.0.0",
  "title": "CameraGrammar",
  "description": "The camera grammar vocabulary (decision 2026-07-04: JSON data; code interprets, data defines). ShotSpec.camera_setup and CameraCue.camera_setup must reference a camera_id defined here.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "cameras"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "cameras": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["camera_id", "framing", "description"],
        "properties": {
          "camera_id": { "type": "string", "pattern": "^cam_[a-z0-9_]+$" },
          "framing": { "enum": ["establishing", "two_shot", "close_on"] },
          "description": { "type": "string", "minLength": 1 },
          "subject_marks": {
            "type": "array",
            "description": "Marks the framing centers on.",
            "items": { "type": "string", "pattern": "^[a-z][a-zA-Z0-9_]*$" }
          },
          "lens_mm": { "type": "number", "exclusiveMinimum": 0 },
          "scene_object": {
            "type": "string",
            "description": "Camera object name in the set/placeholder asset, when pre-placed.",
            "pattern": "^[a-z][a-zA-Z0-9_]*$"
          }
        }
      }
    }
  }
}
